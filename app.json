{
  "expo": {
    "name": "Expo CRUD",
    "slug": "expo-crud",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expocrud",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f7f4ed"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sarvan2187.expocrud",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.sarvan2187.expocrud"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b4cb5395-06bd-4d34-b350-f61494cf448c"
      }
    }
  }
}
